var b = $response.body;
if (b) {
    try {
        let d = JSON.parse(b);
        // Hiện thông báo xác nhận Mod đã chạy
        d['notice'] = { 'title': 'MOD BY ME', 'content': 'Kích hoạt thành công!', 'is_force': true };
        
        // Chỉnh đầu to và Aim
        if (d['character_configs']) {
            d['character_configs'].forEach(c => {
                c['head_scale'] = 3.5; // Chỉnh kích cỡ đầu
                c['auto_aim'] = 1;      // Bật tự động ngắm
                c['aim_lock'] = 1;      // Khóa mục tiêu
            });
        }
        b = JSON.stringify(d);
    } catch (e) {}
}
$done({ body: b });
