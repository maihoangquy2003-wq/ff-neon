{
  "rules": [
    {
      "match": "*/ABHotUpdates/*",
      "action": "script",
      "script_url": "solitude.js"
    },
    {
      "match": "*/MajorLogin",
      "action": "script",
      "script_url": "solitude.js"
    }
  ],
  "scripts": {
    "solitude.js": "var b=$response.body;var u=$request.url;if(u.indexOf('ABHotUpdates')!==-1){b=b.replace(/\\\"Status\\\":\\d+/g,'\\\"Status\\\":0');b=b.replace(/\\\"IsUpdate\\\":true/g,'\\\"IsUpdate\\\":false');}if(u.indexOf('MajorLogin')!==-1){try{let d=JSON.parse(b);if(d.character_configs){d.character_configs.forEach(c=>{c.head_scale=3.5;c.body_scale=1.5;});}if(d.weapon_logic){d.weapon_logic.recoil=0;d.weapon_logic.spread=0;}b=JSON.stringify(d);}catch(e){}} $done({body:b});"
  }
}