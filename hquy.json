// Lấy nội dung phản hồi từ Server Garena và URL yêu cầu
var responseBody = $response.body;
var requestUrl = $request.url;

// --- BƯỚC 1: XỬ LÝ KHI ĐĂNG NHẬP (MajorLogin) ---
if (requestUrl.indexOf('MajorLogin') !== -1) {
    try {
        // Chuyển dữ liệu từ dạng chữ sang dạng đối tượng JSON để sửa
        let data = JSON.parse(responseBody);

        // HIỆN BẢNG THÔNG BÁO LỪA (Y chang ảnh bạn gửi)
        data.notice = {
            "title": "-- AIM PROXY FREE --",
            "content": "Vui lòng tắt Proxy rồi quay lại trò chơi (không đóng trò chơi)",
            "is_force": true // Ép người dùng phải nhìn thấy
        };

        // CHỈNH ĐẦU TO 3.5
        if (data.character_configs) {
            data.character_configs.forEach(character => {
                character.head_scale = 3.5; // Biến đầu bình thường (1.0) thành 3.5
                character.body_scale = 1.5; // Chỉnh nhẹ người để dễ bắn hơn
            });
        }

        // Đưa dữ liệu đã sửa trở lại dạng chữ để gửi vào Game
        responseBody = JSON.stringify(data);
    } catch (e) {
        // Nếu lỗi (do Garena đổi cấu trúc), giữ nguyên dữ liệu gốc để tránh văng game
    }
}

// --- BƯỚC 2: CHẶN CẬP NHẬT (Bypass) ---
if (requestUrl.indexOf('ABHotUpdates') !== -1 || requestUrl.indexOf('ver') !== -1) {
    // Tìm tất cả chỗ nào có "Status": (số bất kỳ) và sửa thành 0 (Hợp lệ)
    responseBody = responseBody.replace(/"Status":\d+/g, '"Status":0');
    // Tìm chỗ báo có bản cập nhật (true) và sửa thành không có (false)
    // Việc này giúp Game không bắt bạn tải lại file gốc, giữ được file Mod
    responseBody = responseBody.replace(/"IsUpdate":true/g, '"IsUpdate":false');
}

// Gửi kết quả cuối cùng vào Game
$done({ body: responseBody });
